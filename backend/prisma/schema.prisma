generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  incidents Incident[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Incident {
  id          String   @id @default(cuid())
  title       String
  description String
  status      String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}